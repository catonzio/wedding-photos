# ── Guest-facing access ──────────────────────────────────────────────────────
# Required. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_TOKEN=change-me

# ── Admin access ─────────────────────────────────────────────────────────────
# Protects POST /api/admin/reload-guests. Must differ from SECRET_TOKEN.
ADMIN_TOKEN=change-me-admin

# ── Tables configuration ──────────────────────────────────────────────────────
TABLES_YAML=tables.yaml

# ── Guest list ───────────────────────────────────────────────────────────────
GUESTS_YAML=guests.yaml

# ── Database (PostgreSQL via asyncpg) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wedding:wedding@db:5432/wedding

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wedding-uploads
# Set to "false" in production with TLS
MINIO_SECURE=false
