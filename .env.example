# ── Guest-facing access ──────────────────────────────────────────────────────
# Required. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_TOKEN=change-me

# ── Admin access ─────────────────────────────────────────────────────────────
# Protects POST /api/admin/reload-guests. Must differ from SECRET_TOKEN.
ADMIN_TOKEN=change-me-admin

# ── Tables configuration ──────────────────────────────────────────────────────
TABLES_YAML=data/tables.yaml

# ── Guest list ───────────────────────────────────────────────────────────────
GUESTS_YAML=data/guests.yaml

# ── Database (PostgreSQL via asyncpg) ─────────────────────────────────────────
DATABASE_USERNAME=username
DATABASE_PASSWORD=password
# DATABASE_HOST=localhost
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=wedding

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
# MINIO_HOST=localhost
# MINIO_PORT=9500
MINIO_DASHBOARD_PORT=9501
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wedding-uploads
# Set to "false" in production with TLS
MINIO_SECURE=false
